# Cloudflare Tunnel config for ansabrasil.org (local hosting).
# Copy to config.yml and fill in your tunnel ID and credentials path.
#
# 1. cloudflared tunnel login
# 2. cloudflared tunnel create ansa-local
# 3. In Cloudflare DNS: CNAME @ and www -> <TUNNEL_ID>.cfargotunnel.com (see docs/MIGRATE_ANSABRASIL_LOCAL.md)
# 4. Set tunnel + credentials-file below, then: cloudflared tunnel --config cloudflared\config.yml run ansa-local

tunnel: <TUNNEL_ID>
credentials-file: <PATH_TO_CREDENTIALS_JSON>

ingress:
  - hostname: ansabrasil.org
    service: http://localhost:4545
  - hostname: www.ansabrasil.org
    service: http://localhost:4545
  - service: http_status:404
