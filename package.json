{
  "name": "ansa-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "web:dev": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "web:start": "cd apps/web && npm start",
    "db:migrate": "cd apps/web && npm run db:migrate",
    "content:check": "cd apps/web && npm run content:check",
    "assets:check": "node apps/web/scripts/check-deployed-images.js --local-only",
    "deploy:check-images": "node apps/web/scripts/check-deployed-images.js",
    "api:dev": "cd apps/api && npm run dev",
    "api:build": "cd apps/api && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "gray-matter": "^4.0.3",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1"
  }
}
