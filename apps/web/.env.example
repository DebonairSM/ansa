# Email: use either Resend or Gmail (if both set, Resend is used).
# Resend (newsletter + contact). For production, verify your domain and set from-addresses.
RESEND_API_KEY=
RESEND_FROM_NEWSLETTER=
RESEND_FROM_CONTACT=

# Gmail SMTP (alternative to Resend). Use an App Password: Google Account > Security > 2-Step Verification > App passwords.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional: custom From display (defaults to GMAIL_USER)
# GMAIL_FROM_NEWSLETTER=ANSA Newsletter <your@gmail.com>
# GMAIL_FROM_CONTACT=ANSA Contact <your@gmail.com>

# Supabase (newsletter + app). Use your project's URL and service_role key from Dashboard > Settings > API.
# If you see ENOTFOUND or connection errors, check the dashboard: paused projects must be restored.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# Admin + site. For production use a strong ADMIN_SECRET; optional: add Google OAuth (see README).
ADMIN_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:4545

# Optional: Google OAuth for admin (NextAuth). Put these in .env.local (local) or your host's env (production).
# Never commit real values. .env.local is gitignored.
# AUTH_GOOGLE_ID=your-google-oauth-client-id
# AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
# AUTH_ADMIN_EMAILS=one@example.com,two@example.com
# NEXTAUTH_SECRET=  (required when using Google; generate: openssl rand -base64 32)
# NEXTAUTH_URL=https://ansa-brasil.org  (canonical site URL; use https://localhost:4545 for local dev)
